{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build active file",
            "command": "C:\\msys64\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++17",
                "${workspaceFolder}/main.cpp",
                "${workspaceFolder}/src/Ball.cpp",
                "${workspaceFolder}/src/Ground.cpp",
                "${workspaceFolder}/src/Obstacle.cpp",
                "${workspaceFolder}/src/Scene.cpp",
                "${workspaceFolder}/src/camera/Camera.cpp",
                "${workspaceFolder}/external/GLAD/src/glad.c",
                "-I${workspaceFolder}/external/GLAD/include",
                "-I${workspaceFolder}/external/glfw-3.4.bin.WIN64/include",
                "-I${workspaceFolder}",
                "-I${workspaceFolder}/src",
                "-L${workspaceFolder}/external/glfw-3.4.bin.WIN64/lib-mingw-w64",
                "-lglfw3dll",
                "-lopengl32",
                "-o",
                "${workspaceFolder}/main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build 3D Ball Rolling Game with g++"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe build active file",
            "command": "C:\\msys64\\mingw64\\bin\\gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/main.cpp",
                "${workspaceFolder}/src/Ball.cpp",
                "${workspaceFolder}/src/Ground.cpp",
                "${workspaceFolder}/src/Obstacle.cpp",
                "${workspaceFolder}/src/Scene.cpp",
                "${workspaceFolder}/src/camera/Camera.cpp",
                "${workspaceFolder}/external/GLAD/src/glad.c",
                "-I${workspaceFolder}/external/GLAD/include",
                "-I${workspaceFolder}/external/glfw-3.4.bin.WIN64/include",
                "-I${workspaceFolder}",
                "-I${workspaceFolder}/src",
                "-L${workspaceFolder}/external/glfw-3.4.bin.WIN64/lib-mingw-w64",
                "-lglfw3dll",
                "-lopengl32",
                "-lstdc++",
                "-o",
                "${workspaceFolder}/main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Build 3D Ball Rolling Game with gcc"
        }
    ],
    "version": "2.0.0"
}